# ─────────────────────────────────────────────────────────────
#  .env.example  —  copy to .env and fill in your values
#  .env is gitignored and never committed to GitHub
# ─────────────────────────────────────────────────────────────

# Airtable
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=All Sessions
AIRTABLE_ATTACHMENT_FIELD=Session open graph
AIRTABLE_TRIGGER_FIELD=Ready for Design
AIRTABLE_IMGBB_API_KEY=your_imgbb_key_here

# Figma
FIGMA_API_KEY=figd_XXXXXXXXXXXXXXXXXXXXXXXX
FIGMA_FILE_KEY=AbCdEfGhIjKlMnOp
FIGMA_FRAME_NODE_ID=1:2
FIGMA_EXPORT_SCALE=2

# Server
SERVER_PORT=5001
SERVER_POLL_INTERVAL=30
SERVER_WEBHOOK_SECRET=

# Field mappings (Airtable field=Figma layer, comma-separated)
FIELD_MAPPINGS=Session Title=Title,Speaker 1 Name=Speaker name,Speaker 1 tagline=Job
IMAGE_FIELD_MAPPINGS=Speaker 1 picture=Photo
