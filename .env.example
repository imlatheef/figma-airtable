# .env.example  —  copy to .env and fill in your real values.
# This file is safe to commit. .env must NOT be committed.

# Airtable personal access token
# Create one at: https://airtable.com/create/tokens
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# imgbb.com API key (free) — needed for reliable image uploads to Airtable
# Get one at: https://imgbb.com/api  (takes 30 seconds)
AIRTABLE_IMGBB_API_KEY=

# Figma personal access token
# Create one at: figma.com → Account Settings → Personal Access Tokens
FIGMA_API_KEY=figd_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# How often to check Airtable for new records (seconds)
POLL_INTERVAL=30
